@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&display=swap');

/* ===================================================
   RESET & BASE
   =================================================== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  /* Colors */
  --bg: #F9F8F6;
  --surface: #FFFFFF;
  --border: #EBEBEA;
  --border-strong: #D4D4D2;
  --text: #18181B;
  --text-2: #71717A;
  --text-3: #A1A1AA;
  --accent: #18181B;
  --accent-fg: #FFFFFF;
  --red: #DC2626;    --red-bg: #FEF2F2;
  --amber: #D97706;  --amber-bg: #FFFBEB;
  --green: #16A34A;  --green-bg: #F0FDF4;
  --indigo: #4F46E5; --indigo-bg: #EEF2FF;
  --orange: #EA580C; --orange-bg: #FFF7ED;
  --blue: #2563EB;   --blue-bg: #EFF6FF;
  /* Layout */
  --radius: 10px;
  --radius-sm: 6px;
  /* Responsive padding */
  --page-px: clamp(16px, 4vw, 40px);
  --page-pb: clamp(60px, 10vh, 100px);
}

html {
  /* Prevent tap-highlight on mobile */
  -webkit-tap-highlight-color: transparent;
}

body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  /* Use dvh so iOS toolbar doesn't cause overflow */
  min-height: 100dvh;
  font-size: 14px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  /* Prevent horizontal scroll */
  overflow-x: hidden;
}

/* Ensure all form elements inherit font */
input, select, button, textarea {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  /* Minimum touch target: 44px per Apple HIG */
}

/* Smooth scrolling */
html { scroll-behavior: smooth; }

/* Focus visible (accessibility) */
:focus-visible {
  outline: 2px solid var(--indigo);
  outline-offset: 2px;
  border-radius: 4px;
}
:focus:not(:focus-visible) { outline: none; }

/* ===================================================
   LAYOUT WRAPPER
   =================================================== */
.wrap {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 var(--page-px) var(--page-pb);
}

/* ===================================================
   TOPBAR
   =================================================== */
.topbar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: clamp(28px, 5vh, 48px) 0 clamp(20px, 3vh, 32px);
  border-bottom: 1px solid var(--border);
  gap: 16px;
}
.topbar-kicker {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .1em;
  color: var(--text-3);
  text-transform: uppercase;
  margin-bottom: 6px;
}
.topbar-title {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(28px, 4vw, 38px);
  font-weight: 400;
  line-height: 1;
}
.topbar-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8px;
  flex-shrink: 0;
}
.topbar-date { font-size: 12px; color: var(--text-3); }
.saved-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--green);
  opacity: 0;
  transition: opacity .3s;
}
.saved-dot.show { opacity: 1; }
.sync-badge {
  font-size: 10px;
  font-weight: 500;
  color: var(--text-3);
  padding: 2px 7px;
  border-radius: 10px;
  background: var(--bg);
  border: 1px solid var(--border);
  opacity: 0;
  transition: opacity .3s;
}
.sync-badge.show { opacity: 1; }

/* ===================================================
   STATS STRIP
   =================================================== */
.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
  border-bottom: 1px solid var(--border);
}
.stat { background: var(--bg); padding: 20px 0; text-align: center; }
.stat-n {
  font-size: clamp(18px, 3vw, 22px);
  font-weight: 300;
  line-height: 1;
  letter-spacing: -.02em;
}
.stat-l {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: .07em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-top: 5px;
}

/* ===================================================
   SECTION LABELS
   =================================================== */
.section-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--text-3);
  margin: 28px 0 12px;
}

/* ===================================================
   TWO-COLUMN GRID (Tasks view)
   =================================================== */
.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr 0.75fr;
  gap: clamp(20px, 3vw, 36px);
  align-items: start;
  margin-top: 0;
}
.col-left, .col-right, .col-quick { min-width: 0; }
/* Divider between stacked cols on mobile */
.col-divider { display: none; }

/* ===================================================
   ADD FORM
   =================================================== */
.add-main {
  display: flex;
  align-items: center;
  border: 1px solid var(--border-strong);
  border-radius: var(--radius);
  background: var(--surface);
  overflow: hidden;
  transition: border-color .15s;
}
.add-main:focus-within { border-color: var(--text); }
.add-input {
  flex: 1;
  padding: 13px 16px;
  border: none;
  background: transparent;
  font-size: 14px;
  color: var(--text);
  outline: none;
  min-width: 0;
}
.add-input::placeholder { color: var(--text-3); }
.add-submit {
  background: var(--accent);
  color: var(--accent-fg);
  border: none;
  padding: 0 18px;
  height: 46px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: opacity .15s;
  white-space: nowrap;
  flex-shrink: 0;
}
.add-submit:hover { opacity: .82; }
.add-meta {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
  margin-top: 8px;
}
.meta-sel {
  padding: 9px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--surface);
  color: var(--text-2);
  cursor: pointer;
  appearance: none;
  -webkit-appearance: none;
  font-size: 13px;
  transition: border-color .15s;
  width: 100%;
}
.meta-sel:focus { outline: none; border-color: var(--text); }
.meta-sel:hover { border-color: var(--border-strong); }
.note-inp {
  width: 100%;
  padding: 9px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--surface);
  color: var(--text);
  font-size: 13px;
  resize: none;
  line-height: 1.55;
  transition: border-color .15s;
  margin-top: 8px;
}
.note-inp:focus { outline: none; border-color: var(--text); }
.note-inp::placeholder { color: var(--text-3); }
.todo-note {
  font-size: 12px;
  color: var(--text-3);
  margin-top: 5px;
  line-height: 1.55;
  white-space: pre-wrap;
}

/* ===================================================
   FILTERS
   =================================================== */
.filters { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 4px; }
.filt {
  padding: 6px 12px;
  border-radius: 20px;
  border: 1px solid transparent;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-2);
  cursor: pointer;
  background: transparent;
  transition: all .15s;
  display: flex; align-items: center; gap: 5px;
  /* min touch target */
  min-height: 36px;
}
.filt:hover { background: var(--surface); border-color: var(--border); }
.filt.active { background: var(--text); color: #fff; border-color: var(--text); }
.filt-count { font-size: 11px; opacity: .7; }

/* ===================================================
   TODO LIST
   =================================================== */
.todo-list { display: flex; flex-direction: column; }
.todo-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
  transition: opacity .2s;
  animation: fadeUp .18s ease;
}
.todo-item:first-child { border-top: 1px solid var(--border); }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.todo-item.is-done { opacity: .4; }
.check {
  width: 20px; height: 20px; min-width: 20px;
  border-radius: 50%;
  border: 1.5px solid var(--border-strong);
  background: transparent;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  margin-top: 2px;
  transition: all .15s;
  flex-shrink: 0;
  /* Bigger touch target */
  padding: 0;
}
.check:hover { border-color: var(--text); }
.check.checked { background: var(--text); border-color: var(--text); }
.todo-body { flex: 1; min-width: 0; }
.todo-text { font-size: 14px; line-height: 1.5; color: var(--text); font-weight: 400; }
.is-done .todo-text { text-decoration: line-through; color: var(--text-3); }
.todo-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 5px; align-items: center; }
.tag { font-size: 11px; font-weight: 500; padding: 2px 8px; border-radius: 4px; }
.tag-high { background: var(--red-bg);   color: var(--red); }
.tag-mid  { background: var(--amber-bg); color: var(--amber); }
.tag-low  { background: var(--green-bg); color: var(--green); }
.tag-cat  { background: transparent; color: var(--text-3); border: 1px solid var(--border); font-weight: 400; }
.tag-date { font-size: 11px; color: var(--text-3); }
.tag-date.od { color: var(--red); font-weight: 500; }
.tag-date.td { color: var(--amber); font-weight: 500; }
.del-btn, .edit-btn {
  opacity: 0;
  background: none;
  border: none;
  color: var(--text-3);
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 16px;
  line-height: 1;
  transition: opacity .15s, color .15s;
  flex-shrink: 0;
  /* Always show on touch devices */
  min-width: 36px; min-height: 36px;
  display: flex; align-items: center; justify-content: center;
}
.todo-item:hover .del-btn, .todo-item:hover .edit-btn { opacity: 1; }
@media (hover: none) {
  /* On touch devices, always show actions */
  .del-btn, .edit-btn { opacity: 0.6; }
}
.del-btn:hover  { color: var(--red); }
.edit-btn:hover { color: var(--text); }
.item-actions { display: flex; gap: 2px; align-items: center; margin-left: 4px; flex-shrink: 0; }

/* ===================================================
   PROGRESS BAR
   =================================================== */
.prog-wrap { margin-top: 24px; }
.prog-head {
  display: flex;
  justify-content: space-between;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: .07em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 8px;
}
.prog-track { height: 1px; background: var(--border); border-radius: 1px; overflow: hidden; }
.prog-fill   { height: 100%; background: var(--text); border-radius: 1px; transition: width .5s ease; }

/* ===================================================
   CALENDAR REMINDERS
   =================================================== */
.reminder-section { margin-top: 0; padding-top: 0; border-top: none; }
.rem-form { display: grid; grid-template-columns: 1fr; gap: 6px; margin-bottom: 16px; }
.rem-form-row { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
.rem-text-inp {
  flex: 1;
  padding: 10px 13px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--surface);
  color: var(--text);
  font-size: 13px;
  transition: border-color .15s;
  min-width: 0;
}
.rem-text-inp:focus { outline: none; border-color: var(--text); }
.rem-text-inp::placeholder { color: var(--text-3); }
.rem-date-inp {
  flex: 1;
  padding: 9px 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--surface);
  color: var(--text-2);
  font-size: 12px;
  transition: border-color .15s;
  min-width: 100px;
}
.rem-date-inp:focus { outline: none; border-color: var(--text); }
.rem-date-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: .07em;
  text-transform: uppercase;
  color: var(--text-3);
  white-space: nowrap;
}
.rem-add-btn {
  background: var(--accent);
  color: #fff;
  border: none;
  border-radius: var(--radius-sm);
  padding: 10px 16px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity .15s;
  min-height: 40px;
}
.rem-add-btn:hover { opacity: .82; }

/* Calendar nav */
.cal-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
.cal-nav-btn {
  background: none;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 6px 14px;
  font-size: 13px;
  cursor: pointer;
  color: var(--text-2);
  transition: all .15s;
  line-height: 1;
  min-height: 36px;
}
.cal-nav-btn:hover { border-color: var(--border-strong); color: var(--text); }
.cal-kw       { font-size: 13px; font-weight: 500; color: var(--text); text-align: center; }
.cal-kw-range { font-size: 10px; font-weight: 500; letter-spacing: .06em; text-transform: uppercase; color: var(--text-3); text-align: center; margin-top: 2px; }
.cal-today-btn {
  font-size: 11px;
  font-weight: 500;
  color: var(--indigo);
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 4px;
  transition: background .15s;
  display: block;
  margin: 4px auto 14px;
  min-height: 32px;
}
.cal-today-btn:hover { background: var(--indigo-bg); }

/* Calendar grid */
.cal-grid-wrap { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: var(--surface); }
.cal-header { display: grid; grid-template-columns: repeat(7, 1fr); border-bottom: 1px solid var(--border); }
.cal-header-day { padding: 10px 4px; text-align: center; border-right: 1px solid var(--border); }
.cal-header-day:last-child { border-right: none; }
.cal-header-day.is-today { background: var(--indigo-bg); }
.cal-header-dayname { font-size: 11px; font-weight: 500; letter-spacing: .07em; text-transform: uppercase; color: var(--text-3); }
.cal-header-day.is-today .cal-header-dayname { color: var(--indigo); }
.cal-header-daynum { font-size: clamp(14px, 2vw, 18px); font-weight: 400; color: var(--text); margin-top: 3px; line-height: 1; }
.cal-header-day.is-today .cal-header-daynum { color: var(--indigo); font-weight: 500; }
.cal-header-month { font-size: 10px; color: var(--text-3); margin-top: 2px; }
.cal-events { padding: 8px 6px; min-height: 60px; position: relative; }
.cal-event {
  height: 28px;
  border-radius: 5px;
  display: flex; align-items: center;
  padding: 0 8px;
  font-size: 12px;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  cursor: pointer;
  position: relative;
  transition: opacity .15s;
  gap: 4px;
  margin-bottom: 2px;
}
.cal-event:hover { opacity: .88; }
.cal-event-label { flex: 1; overflow: hidden; text-overflow: ellipsis; }
.cal-event-actions { display: none; gap: 2px; flex-shrink: 0; }
.cal-event:hover .cal-event-actions { display: flex; }
.cal-event-btn { background: none; border: none; color: inherit; cursor: pointer; font-size: 13px; padding: 0 2px; line-height: 1; opacity: .7; transition: opacity .15s; }
.cal-event-btn:hover { opacity: 1; }
.ev-0 { background: #EEF2FF; color: #4338CA; border-left: 2px solid #6366F1; }
.ev-1 { background: #F0FDF4; color: #166534; border-left: 2px solid #22C55E; }
.ev-2 { background: #FFFBEB; color: #92400E; border-left: 2px solid #F59E0B; }
.ev-3 { background: #FEF2F2; color: #991B1B; border-left: 2px solid #EF4444; }
.ev-4 { background: #F5F3FF; color: #5B21B6; border-left: 2px solid #8B5CF6; }
.ev-5 { background: #ECFDF5; color: #065F46; border-left: 2px solid #10B981; }
.ev-6 { background: #FFF7ED; color: #9A3412; border-left: 2px solid #F97316; }
.cal-empty { text-align: center; padding: 24px 0; color: var(--text-3); font-size: 12px; }

/* Today banner */
.reminder-today { background: var(--indigo-bg); border: 1px solid #C7D2FE; border-radius: var(--radius); padding: 12px 14px; margin-bottom: 14px; animation: fadeUp .2s ease; }
.reminder-today-label { font-size: 10px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--indigo); margin-bottom: 6px; }
.reminder-today-list { display: flex; flex-direction: column; gap: 5px; }
.reminder-today-item { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
.reminder-today-text { font-size: 13px; color: #3730A3; font-weight: 500; line-height: 1.4; }
.reminder-today-del { background: none; border: none; color: #A5B4FC; cursor: pointer; font-size: 16px; padding: 4px; line-height: 1; transition: color .15s; min-width: 32px; min-height: 32px; display: flex; align-items: center; justify-content: center; }
.reminder-today-del:hover { color: var(--red); }

/* ===================================================
   FIREBASE STATUS
   =================================================== */
.fb-toggle {
  font-size: 11px; font-weight: 500; color: var(--text-3);
  background: none; border: 1px solid var(--border); border-radius: var(--radius-sm);
  cursor: pointer; padding: 5px 10px; transition: all .15s;
  display: flex; align-items: center; gap: 4px; white-space: nowrap;
}
.fb-toggle:hover { border-color: var(--border-strong); color: var(--text); }
.fb-toggle.connected { border-color: #BBF7D0; color: var(--green); background: var(--green-bg); }
.fb-panel { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 20px; margin-top: 12px; display: none; }
.fb-panel.open { display: block; }
.fb-panel-head { font-size: 11px; font-weight: 500; letter-spacing: .07em; text-transform: uppercase; color: var(--text-3); margin-bottom: 10px; }
.fb-panel-desc { font-size: 12px; color: var(--text-2); margin-bottom: 12px; line-height: 1.6; }
.fb-panel-desc a { color: var(--indigo); text-decoration: none; }
.fb-textarea { width: 100%; padding: 9px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--bg); color: var(--text); font-size: 11px; font-family: monospace; line-height: 1.5; resize: vertical; min-height: 80px; transition: border-color .15s; }
.fb-textarea:focus { outline: none; border-color: var(--text); }
.fb-actions { display: flex; gap: 8px; margin-top: 10px; align-items: center; flex-wrap: wrap; }
.fb-save-btn { background: var(--text); color: #fff; border: none; border-radius: var(--radius-sm); padding: 8px 16px; font-size: 12px; font-weight: 500; cursor: pointer; transition: opacity .15s; }
.fb-save-btn:hover { opacity: .82; }
.fb-disconnect-btn { font-size: 12px; color: var(--text-3); background: none; border: none; cursor: pointer; padding: 0; transition: color .15s; }
.fb-disconnect-btn:hover { color: var(--red); }
.fb-status { font-size: 11px; margin-left: auto; }
.fb-status.ok  { color: var(--green); }
.fb-status.err { color: var(--red); }

/* ===================================================
   QUICK NOTES
   =================================================== */
.quick-section { margin-top: 0; position: sticky; top: 20px; }
.quick-pad { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
.quick-input-wrap { padding: 12px 14px; border-bottom: 1px solid var(--border); }
.quick-textarea { width: 100%; border: none; background: transparent; font-size: 13px; color: var(--text); line-height: 1.6; resize: none; outline: none; font-family: 'Inter', sans-serif; min-height: 80px; }
.quick-textarea::placeholder { color: var(--text-3); }
.quick-footer { padding: 8px 14px; display: flex; align-items: center; justify-content: space-between; background: var(--bg); }
.quick-add-btn { background: var(--text); color: #fff; border: none; border-radius: var(--radius-sm); padding: 8px 16px; font-size: 12px; font-weight: 500; cursor: pointer; transition: opacity .15s; min-height: 36px; }
.quick-add-btn:hover { opacity: .82; }
.quick-clear-btn { font-size: 11px; color: var(--text-3); background: none; border: none; cursor: pointer; padding: 4px; transition: color .15s; }
.quick-clear-btn:hover { color: var(--red); }
.quick-notes-list { display: flex; flex-direction: column; }
.quick-note { padding: 12px 14px; border-bottom: 1px solid var(--border); animation: fadeUp .15s ease; transition: background .15s; }
.quick-note:last-child { border-bottom: none; }
.quick-note:hover { background: var(--bg); }
.quick-note-text { font-size: 13px; color: var(--text); line-height: 1.6; white-space: pre-wrap; word-break: break-word; }
.quick-note-meta { display: flex; align-items: center; justify-content: space-between; margin-top: 8px; gap: 6px; flex-wrap: wrap; }
.quick-note-time { font-size: 10px; color: var(--text-3); }
.quick-note-actions { display: flex; gap: 4px; flex-wrap: wrap; }
.qn-btn {
  font-size: 10px; font-weight: 500; padding: 4px 8px; border-radius: 10px;
  border: 1px solid var(--border); background: transparent; cursor: pointer;
  transition: all .15s; white-space: nowrap; color: var(--text-2);
  min-height: 28px;
}
.qn-btn:hover                { background: var(--surface); border-color: var(--border-strong); }
.qn-btn.task                  { color: #166534; border-color: #BBF7D0; background: #F0FDF4; }
.qn-btn.task:hover            { background: #DCFCE7; }
.qn-btn.reminder              { color: #4338CA; border-color: #C7D2FE; background: #EEF2FF; }
.qn-btn.reminder:hover        { background: #E0E7FF; }
.qn-btn.allg                  { color: #92400E; border-color: #FDE68A; background: #FFFBEB; }
.qn-btn.allg:hover            { background: #FEF3C7; }
.qn-btn.del                   { color: var(--text-3); border-color: var(--border); }
.qn-btn.del:hover             { color: var(--red); border-color: #FECACA; background: var(--red-bg); }
.quick-empty { padding: 24px 14px; text-align: center; color: var(--text-3); font-size: 12px; line-height: 1.6; }
.quick-count { font-size: 10px; font-weight: 500; letter-spacing: .06em; text-transform: uppercase; color: var(--text-3); padding: 8px 14px 4px; border-bottom: 1px solid var(--border); }

/* ===================================================
   GENERAL NOTES (Allgemeine Dinge)
   =================================================== */
.notes-section { margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border); }
.notes-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.notes-search-wrap { position: relative; margin-bottom: 12px; }
.notes-search {
  width: 100%; padding: 10px 13px 10px 34px;
  border: 1px solid var(--border); border-radius: var(--radius-sm);
  background: var(--surface); color: var(--text); font-size: 13px;
  transition: border-color .15s;
}
.notes-search:focus { outline: none; border-color: var(--text); }
.notes-search::placeholder { color: var(--text-3); }
.notes-search-icon { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); color: var(--text-3); font-size: 13px; pointer-events: none; }
.notes-add-btn {
  background: none; border: 1px solid var(--border); border-radius: var(--radius-sm);
  padding: 7px 14px; font-size: 12px; font-weight: 500; color: var(--text-2); cursor: pointer;
  transition: all .15s; display: flex; align-items: center; gap: 5px; white-space: nowrap;
  min-height: 36px;
}
.notes-add-btn:hover { border-color: var(--border-strong); color: var(--text); background: var(--surface); }
.notes-list { display: flex; flex-direction: column; gap: 6px; }
.note-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 12px 14px; cursor: pointer; transition: border-color .15s; animation: fadeUp .18s ease; }
.note-card:hover { border-color: var(--border-strong); }
.note-card-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
.note-card-title { font-size: 13px; font-weight: 500; color: var(--text); line-height: 1.4; flex: 1; }
.note-card-actions { display: flex; gap: 2px; flex-shrink: 0; opacity: 0; transition: opacity .15s; }
.note-card:hover .note-card-actions { opacity: 1; }
@media (hover: none) { .note-card-actions { opacity: 1; } }
.note-card-btn { background: none; border: none; color: var(--text-3); cursor: pointer; padding: 4px 6px; border-radius: 4px; font-size: 13px; line-height: 1; transition: color .15s; min-height: 32px; }
.note-card-btn:hover { color: var(--text); }
.note-card-btn.del:hover { color: var(--red); }
.note-card-body { font-size: 12px; color: var(--text-2); margin-top: 5px; line-height: 1.6; white-space: pre-wrap; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
.note-card.expanded .note-card-body { -webkit-line-clamp: unset; overflow: visible; }
.note-card-date { font-size: 10px; color: var(--text-3); margin-top: 6px; letter-spacing: .03em; }
.notes-empty { text-align: center; padding: 28px 0; color: var(--text-3); font-size: 13px; }
.notes-count { font-size: 11px; color: var(--text-3); margin-bottom: 8px; }

/* ===================================================
   MODAL
   =================================================== */
.modal-backdrop {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, .3);
  z-index: 200;
  align-items: center;
  justify-content: center;
  padding: 16px;
}
.modal-backdrop.open { display: flex; }
.modal {
  background: var(--surface);
  border-radius: 14px;
  padding: clamp(18px, 4vw, 28px);
  width: 100%;
  max-width: 480px;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 8px 40px rgba(0, 0, 0, .14);
  animation: modalIn .18s ease;
}
@keyframes modalIn {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}
.modal-title { font-family: 'Instrument Serif', serif; font-size: 22px; font-weight: 400; margin-bottom: 20px; }
.modal-field { margin-bottom: 12px; }
.modal-label { font-size: 10px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; color: var(--text-3); margin-bottom: 5px; }
.modal-inp {
  width: 100%; padding: 10px 12px;
  border: 1px solid var(--border); border-radius: var(--radius-sm);
  background: var(--bg); color: var(--text); font-size: 14px;
  transition: border-color .15s;
}
.modal-inp:focus { outline: none; border-color: var(--text); }
.modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 12px; }
.modal-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border); flex-wrap: wrap; }
.btn-cancel {
  padding: 10px 18px; border: 1px solid var(--border); border-radius: var(--radius-sm);
  background: transparent; color: var(--text-2); font-size: 13px; font-weight: 500;
  cursor: pointer; transition: all .15s; min-height: 40px;
}
.btn-cancel:hover { border-color: var(--border-strong); color: var(--text); }
.btn-save {
  padding: 10px 18px; border: none; border-radius: var(--radius-sm);
  background: var(--text); color: #fff; font-size: 13px; font-weight: 500;
  cursor: pointer; transition: opacity .15s; min-height: 40px;
}
.btn-save:hover { opacity: .82; }
.btn-save:disabled { opacity: .4; cursor: not-allowed; }

/* ===================================================
   AI ASSISTANT
   =================================================== */
.ai-section { margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border); grid-column: 1 / -1; }
.ai-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; flex-wrap: wrap; gap: 8px; }
.ai-btns { display: flex; gap: 6px; flex-wrap: wrap; }
.ai-btn {
  font-size: 12px; font-weight: 500; padding: 8px 14px;
  border-radius: 20px; border: 1px solid var(--border); background: var(--surface);
  color: var(--text-2); cursor: pointer; transition: all .15s; min-height: 36px;
}
.ai-btn:hover { border-color: var(--border-strong); color: var(--text); }
.ai-btn:disabled { opacity: .5; cursor: not-allowed; }
.ai-result { margin-top: 16px; padding: 16px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); }
.ai-result-kicker { font-size: 10px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--text-3); margin-bottom: 10px; }
.ai-result-text { font-size: 13px; color: var(--text); line-height: 1.8; white-space: pre-wrap; }
.ai-close { font-size: 11px; color: var(--text-3); background: none; border: none; cursor: pointer; margin-top: 10px; padding: 0; letter-spacing: .04em; text-transform: uppercase; font-weight: 500; }
.ai-close:hover { color: var(--text); }
.key-toggle { font-size: 10px; font-weight: 500; color: var(--text-3); background: none; border: none; cursor: pointer; letter-spacing: .08em; text-transform: uppercase; padding: 0; transition: color .15s; }
.key-toggle:hover { color: var(--text); }
.key-panel { margin-top: 14px; padding: 16px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); }
.key-desc { font-size: 12px; color: var(--text-3); margin-bottom: 12px; line-height: 1.6; }
.key-desc a { color: var(--indigo); text-decoration: none; }
.key-row { display: flex; gap: 8px; flex-wrap: wrap; }
.key-input { flex: 1; min-width: 200px; padding: 9px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); font-family: monospace; font-size: 12px; background: var(--bg); color: var(--text); }
.key-input:focus { outline: none; border-color: var(--text); }
.key-save { padding: 9px 16px; background: var(--text); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 12px; font-weight: 500; cursor: pointer; white-space: nowrap; transition: opacity .15s; }
.key-save:hover { opacity: .8; }
.key-ok { font-size: 11px; color: var(--green); margin-top: 8px; display: none; }

/* ===================================================
   LOADING DOTS
   =================================================== */
.dots { display: flex; gap: 5px; align-items: center; height: 20px; }
.dot  { width: 5px; height: 5px; border-radius: 50%; background: var(--text-2); }
.dot:nth-child(1) { animation: pulse 1.1s ease-in-out 0s infinite; }
.dot:nth-child(2) { animation: pulse 1.1s ease-in-out .18s infinite; }
.dot:nth-child(3) { animation: pulse 1.1s ease-in-out .36s infinite; }
@keyframes pulse {
  0%, 100% { transform: scale(.7); opacity: .3; }
  50%       { transform: scale(1.1); opacity: 1; }
}

/* ===================================================
   MISC
   =================================================== */
.empty { padding: 40px 0; text-align: center; color: var(--text-3); font-size: 13px; }

/* ===================================================
   RESPONSIVE BREAKPOINTS
   =================================================== */

/* --- Tablet: ≤ 1024px --- */
@media (max-width: 1024px) {
  .two-col {
    grid-template-columns: 1fr 1fr;
  }
  .col-quick {
    grid-column: 1 / -1;
    border-top: 1px solid var(--border);
    padding-top: 24px;
    margin-top: 8px;
  }
  .col-quick .quick-section { position: static; }
  .ai-section { grid-column: 1 / -1; }
}

/* --- Small Tablet / Large Phone: ≤ 768px --- */
@media (max-width: 768px) {
  :root {
    --page-px: 16px;
  }

  .topbar {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: 24px 0 20px;
  }

  .topbar-right {
    width: 100%;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 6px;
  }

  .stats { grid-template-columns: repeat(2, 1fr); }

  .add-meta { grid-template-columns: 1fr 1fr; }

  .two-col {
    grid-template-columns: 1fr;
    gap: 28px;
  }

  .col-right, .col-quick {
    padding-top: 0;
    border-top: none;
    grid-column: auto;
  }
  .col-quick .quick-section { position: static; }

  .rem-form-row { flex-wrap: wrap; }

  /* Month view: responsive layout */
  .cal-header-daynum { font-size: 14px; }
  .cal-events { padding: 4px; min-height: 40px; }
  .cal-event { font-size: 10px; height: 22px; padding: 0 4px; }

  /* Modal full-width on phone */
  .modal {
    max-width: 100%;
    border-radius: 12px;
  }
  .modal-grid { grid-template-columns: 1fr; }

  /* Topbar: hide email on mobile to save space */
  .topbar-email { display: none; }

  /* Month calendar: stack sidebar below grid */
  .month-grid-container {
    grid-template-columns: 1fr !important;
  }
}

/* --- Phone: ≤ 480px --- */
@media (max-width: 480px) {
  .topbar-title { font-size: 24px; }

  .stats .stat { padding: 14px 0; }
  .stat-n { font-size: 20px; }

  .add-meta { grid-template-columns: 1fr 1fr; }

  .filters { gap: 3px; }
  .filt { padding: 5px 10px; font-size: 11px; }

  /* Calendar events: only show colored bar, no labels */
  .cal-event-label { display: none; }
  .cal-events { min-height: 28px; }

  /* Modals */
  .modal-actions { flex-direction: column-reverse; }
  .btn-cancel, .btn-save { width: 100%; justify-content: center; text-align: center; }

  /* Daily stats: 2x2 grid instead of 4 across */
  .daily-stats-grid {
    grid-template-columns: repeat(2, 1fr) !important;
  }

  /* Section heading adjust */
  .section-label { margin: 20px 0 10px; }
}

/* --- Specific: Tab navigation scroll on small screens --- */
.tab-nav-scroll {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.tab-nav-scroll::-webkit-scrollbar { display: none; }

/* ===================================================
   SAFE AREA (iPhone notch / home bar)
   =================================================== */
/* ===================================================
   SAFE AREA (iPhone notch / home bar)
   =================================================== */
@supports (padding-bottom: env(safe-area-inset-bottom)) {
  .wrap {
    padding-bottom: calc(var(--page-pb) + env(safe-area-inset-bottom));
    padding-left: calc(var(--page-px) + env(safe-area-inset-left));
    padding-right: calc(var(--page-px) + env(safe-area-inset-right));
  }
}

/* ===================================================
   DAILY VIEW GRID
   =================================================== */
.daily-view-grid {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 24px;
  align-items: start;
}
@media (max-width: 960px) {
  .daily-view-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}

/* ===================================================
   MONTH VIEW - responsive classes
   =================================================== */
.month-grid-container {
  display: grid;
  grid-template-columns: minmax(0, 1.7fr) 300px;
  gap: 20px;
  align-items: start;
}
@media (max-width: 900px) {
  .month-grid-container {
    grid-template-columns: 1fr !important;
  }
}

/* ===================================================
   CALENDAR REMINDERS - Fix on mobile
   =================================================== */
.reminder-section { margin-top: 0; }
@media (max-width: 768px) {
  .rem-form-row {
    flex-direction: column;
    align-items: stretch;
  }
  .rem-date-inp { min-width: 100%; }
}

/* ===================================================
   PROJECT DETAIL - responsive
   =================================================== */
@media (max-width: 900px) {
  .project-detail-grid {
    grid-template-columns: 1fr !important;
  }
}
